# ─── Supabase ──────────────────────────────────────────────────
# Supabase > Settings > API
VITE_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ─── TMDB (séries & acteurs) ───────────────────────────────────
# https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=ta_cle_tmdb_ici

# ─── RAWG (jeux vidéo) ────────────────────────────────────────
# https://rawg.io/apidocs
VITE_RAWG_API_KEY=ta_cle_rawg_ici

# ─── Giphy (GIFs K-pop) ───────────────────────────────────────
# https://developers.giphy.com
VITE_GIPHY_API_KEY=ta_cle_giphy_ici

# ─── Unsplash (recherche photos Photo-Recap) ──────────────────
# https://unsplash.com/developers
VITE_UNSPLASH_API_KEY=ta_cle_unsplash_ici

# ─── Google Custom Search (images célébrités dans Légendes) ────
# Étape 1 : https://programmablesearchengine.google.com → créer un moteur
# Étape 2 : https://console.developers.google.com → activer Custom Search API
VITE_GOOGLE_SEARCH_KEY=ta_cle_google_ici
VITE_GOOGLE_SEARCH_CX=ton_search_engine_id_ici
